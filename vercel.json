{
  "rewrites": [
    { "source": "/", "destination": "/public/index.html" },
    { "source": "/services", "destination": "/public/services.html" },
    { "source": "/about", "destination": "/public/about.html" },
    { "source": "/service-area", "destination": "/public/service-area.html" },
    { "source": "/reviews", "destination": "/public/reviews.html" },
    { "source": "/contact", "destination": "/public/contact.html" },
    { "source": "/sitemap.xml", "destination": "/public/sitemap.xml" },
    { "source": "/robots.txt", "destination": "/public/robots.txt" },
    { "source": "/llms.txt", "destination": "/public/llms.txt" }
  ],
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [{"key": "Content-Type", "value": "application/xml"}]
    },
    {
      "source": "/robots.txt",
      "headers": [{"key": "Content-Type", "value": "text/plain"}]
    },
    {
      "source": "/llms.txt",
      "headers": [{"key": "Content-Type", "value": "text/plain"}]
    }
  ]
}
